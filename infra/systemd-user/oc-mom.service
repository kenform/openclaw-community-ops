[Unit]
Description=OpenClaw mom agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/openclawuser/.openclaw/workspace
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/openclawuser/.openclaw/workspace/scripts/oc-role-runner.sh mom
Restart=always
RestartSec=5
CPUQuota=60%
MemoryMax=700M
TasksMax=512
TimeoutStopSec=20

[Install]
WantedBy=default.target
