[Unit]
Description=OpenClaw study agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/openclawuser/.openclaw/workspace
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/openclawuser/.openclaw/workspace/scripts/oc-role-runner.sh study
Restart=on-failure
RestartSec=5
CPUQuota=140%
MemoryMax=2000M
TasksMax=512
TimeoutStopSec=20

[Install]
WantedBy=default.target
