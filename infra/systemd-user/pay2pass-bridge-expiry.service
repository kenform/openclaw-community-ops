[Unit]
Description=Pay2Pass bridge daily expiry check
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/home/openclawuser/.openclaw/workspace
EnvironmentFile=/home/openclawuser/.openclaw/workspace/config/pay2pass_bridge.env
ExecStart=/usr/bin/env python3 /home/openclawuser/.openclaw/workspace/scripts/pay2pass_discord_bridge.py --mode expiry-check --env-file /home/openclawuser/.openclaw/workspace/config/pay2pass_bridge.env
